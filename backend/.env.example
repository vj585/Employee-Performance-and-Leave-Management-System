# ==========================================
# ENVIRONMENT VARIABLES CONFIGURATION
# ==========================================

# Port where the backend server will run
PORT=5000

# MongoDB Connection String (Replace with your Atlas or Local URI)
MONGO_URI=mongodb://localhost:27017/employee-ms

# Secret string used to sign JWT tokens (Should be long and random in production)
JWT_SECRET=your_jwt_secret_key_here

# SMTP configuration for sending emails (Optional: If using Nodemailer)
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password

# The environment mode (development or production)
NODE_ENV=development
